    <script>
        // ============================================================
        // ESTRELAS CADENTES
        // ============================================================
        const canvas = document.getElementById('stars-canvas');
        const ctx = canvas.getContext('2d');
        let W, H;

        function resizeCanvas() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
        }
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);

        const stars = [];
        for (let i = 0; i < 180; i++) {
            stars.push({
                x: Math.random() * W,
                y: Math.random() * H,
                r: Math.random() * 1.5 + 0.5,
                alpha: Math.random() * 0.8 + 0.2,
                speed: Math.random() * 0.008 + 0.003,
            });
        }

        let meteors = [];

        function spawnMeteor() {
            const x = Math.random() * W * 0.8 + W * 0.1;
            const y = Math.random() * H * 0.3;
            const angle = Math.PI / 4 + (Math.random() - 0.5) * 0.5;
            const speed = 6 + Math.random() * 10;
            const life = 120 + Math.random() * 100;
            meteors.push({
                x,
                y,
                vx: Math.cos(angle) * speed,
                vy: Math.sin(angle) * speed,
                life,
                maxLife: life,
                size: 2 + Math.random() * 2
            });
        }

        setInterval(() => {
            if (meteors.length < 6) spawnMeteor();
        }, 3000 + Math.random() * 4000);

        for (let i = 0; i < 3; i++) setTimeout(spawnMeteor, i * 800);

        function drawStars() {
            ctx.clearRect(0, 0, W, H);

            stars.forEach(s => {
                const flicker = 0.7 + 0.3 * Math.sin(Date.now() * s.speed);
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 240, 220, ${s.alpha * flicker})`;
                ctx.fill();
            });

            for (let i = meteors.length - 1; i >= 0; i--) {
                const m = meteors[i];
                m.x += m.vx;
                m.y += m.vy;
                m.life--;

                const progress = 1 - (m.life / m.maxLife);
                const alpha = 1 - progress * 0.9;

                const gradient = ctx.createRadialGradient(m.x, m.y, 0, m.x, m.y, m.size * 8);
                gradient.addColorStop(0, `rgba(255, 240, 230, ${alpha})`);
                gradient.addColorStop(0.3, `rgba(200, 180, 255, ${alpha * 0.5})`);
                gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

                ctx.beginPath();
                ctx.arc(m.x, m.y, m.size * 6, 0, Math.PI * 2);
                ctx.fillStyle = gradient;
                ctx.fill();

                ctx.beginPath();
                ctx.arc(m.x, m.y, m.size * 0.8, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${alpha * 0.9})`;
                ctx.fill();

                if (m.life <= 0 || m.x > W + 50 || m.y > H + 50) {
                    meteors.splice(i, 1);
                }
            }

            requestAnimationFrame(drawStars);
        }
        drawStars();

        // ============================================================
        // MÚSICA DE FUNDO
        // ============================================================
        const musicBtn = document.getElementById('musicBtn');
        let audioFundo = null;
        let isPlayingFundo = false;

        function initAudioFundo() {
            if (!audioFundo) {
                audioFundo = new Audio('background-music.mp3');
                audioFundo.loop = true;
                audioFundo.volume = 0.3;
            }
        }

        function toggleMusicFundo() {
            initAudioFundo();
            if (isPlayingFundo) {
                audioFundo.pause();
                isPlayingFundo = false;
                musicBtn.textContent = '🔇';
            } else {
                audioFundo.play().catch(() => {});
                isPlayingFundo = true;
                musicBtn.textContent = '🔊';
            }
        }

        musicBtn.addEventListener('click', toggleMusicFundo);

        document.addEventListener('click', () => {
            if (!audioFundo) {
                initAudioFundo();
                audioFundo.play().then(() => {
                    isPlayingFundo = true;
                    musicBtn.textContent = '🔊';
                }).catch(() => {});
            }
        }, { once: true });

        // ============================================================
        // ABRIR CAPÍTULOS
        // ============================================================
        function abrirCapitulo(id) {
            const card = document.getElementById(id);
            if (card) {
                const body = card.querySelector('.capitulo-body');
                if (body) {
                    document.querySelectorAll('.capitulo-body.aberto').forEach(b => {
                        if (b !== body) {
                            b.classList.remove('aberto');
                            const indicador = b.closest('.capitulo-card').querySelector('.abrir-indicador');
                            if (indicador) indicador.textContent = '▼ Clique para ler';
                        }
                    });
                    const isOpen = body.classList.contains('aberto');
                    body.classList.toggle('aberto');
                    const indicador = card.querySelector('.abrir-indicador');
                    if (indicador) {
                        indicador.textContent = isOpen ? '▼ Clique para ler' : '▲ Fechar';
                    }
                    if (!isOpen) {
                        setTimeout(() => {
                            card.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        }, 100);
                    }
                }
            }
        }

        document.querySelectorAll('.capitulo-card').forEach(card => {
            const header = card.querySelector('.capitulo-header');
            if (header) {
                header.style.cursor = 'pointer';
                header.addEventListener('click', function(e) {
                    if (e.target.closest('.btn-proximo')) return;
                    const id = card.id;
                    if (id) abrirCapitulo(id);
                });
            }
        });

        console.log('♑ Capricórnio — layout inovador carregado.');
        console.log('📝 Pronto para receber o texto da história.');
    </script>
</body>
