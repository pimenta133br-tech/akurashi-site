<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Capricórnio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <style>
        /* ============================================================
           RESET
        ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #0a0806;
            color: #e0d6c8;
            font-family: 'Lora', serif;
            line-height: 1.8;
            overflow-x: hidden;
        }

        /* ============================================================
           FUNDO — TERRENO ESCULPIDO PELO TEMPO
        ============================================================ */
        #stars-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
        }

        #fundo-capricornio {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(ellipse at 20% 30%, rgba(160, 130, 80, 0.08), transparent 55%),
                        radial-gradient(ellipse at 80% 70%, rgba(100, 80, 50, 0.06), transparent 50%),
                        radial-gradient(ellipse at 50% 50%, rgba(60, 50, 35, 0.04), transparent 70%);
            animation: terrenoAnim 16s ease-in-out infinite alternate;
        }

        @keyframes terrenoAnim {
            0% {
                transform: scale(1) rotate(0deg);
                opacity: 0.5;
            }
            50% {
                transform: scale(1.08) rotate(1.5deg);
                opacity: 0.9;
            }
            100% {
                transform: scale(0.96) rotate(-1deg);
                opacity: 0.6;
            }
        }

        /* ============================================================
           VINHETA
        ============================================================ */
        #vinheta {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.6) 100%);
        }

        /* ============================================================
           CONTAINER
        ============================================================ */
        .container {
            position: relative;
            z-index: 1;
            max-width: 1100px;
            margin: 0 auto;
            padding: 2rem 1.5rem 4rem;
        }

        /* ============================================================
           HERO — TÍTULO COM EFEITO DE ESCULTURA
        ============================================================ */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 2rem 0;
            position: relative;
        }

        .hero h1 {
            font-family: 'Cinzel', serif;
            font-weight: 900;
            font-size: clamp(3.5rem, 12vw, 6.5rem);
            color: #d4c0a0;
            text-shadow: 0 0 60px rgba(212, 163, 115, 0.15), 0 4px 30px rgba(0, 0, 0, 0.5);
            letter-spacing: 0.15em;
            margin-bottom: 0.5rem;
            animation: esculpir 5s ease-in-out infinite;
            position: relative;
        }

        .hero h1::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 2px;
            background: linear-gradient(to right, transparent, #d4a373, transparent);
            opacity: 0.4;
        }

        @keyframes esculpir {
            0%,
            100% {
                text-shadow: 0 0 60px rgba(212, 163, 115, 0.15), 0 4px 30px rgba(0, 0, 0, 0.5);
                letter-spacing: 0.15em;
            }
            50% {
                text-shadow: 0 0 80px rgba(212, 163, 115, 0.3), 0 4px 40px rgba(0, 0, 0, 0.6);
                letter-spacing: 0.2em;
            }
        }

        .hero .subtitulo {
            font-size: clamp(1rem, 2vw, 1.3rem);
            color: #b8a890;
            font-style: italic;
            max-width: 600px;
            margin-top: 1.5rem;
            opacity: 0.7;
            letter-spacing: 0.05em;
        }

        /* ============================================================
           SEÇÕES — CARDS FLUTUANTES
        ============================================================ */
        section {
            margin: 5rem 0;
            padding: 2rem 0;
            position: relative;
        }

        h2 {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 2.2rem;
            color: #d4c0a0;
            letter-spacing: 0.1em;
            margin-bottom: 2.5rem;
            text-align: center;
            position: relative;
        }

        h2::before {
            content: '✦';
            color: #d4a373;
            font-size: 1.2rem;
            opacity: 0.5;
            margin-right: 0.8rem;
        }

        h2::after {
            content: '';
            position: absolute;
            bottom: -0.8rem;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 1px;
            background: linear-gradient(to right, transparent, rgba(212, 163, 115, 0.3), transparent);
        }

        /* ============================================================
           PERFIL — CARDS FLUTUANTES COM EFEITO 3D
        ============================================================ */
        .perfil-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2.5rem;
            margin-top: 1.5rem;
        }
        @media (max-width: 700px) {
            .perfil-grid {
                grid-template-columns: 1fr;
                gap: 1.5rem;
            }
        }

        .perfil-card {
            background: rgba(20, 17, 14, 0.7);
            padding: 2rem 2.2rem;
            border-radius: 24px;
            border: 1px solid rgba(212, 163, 115, 0.06);
            backdrop-filter: blur(12px);
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2);
            position: relative;
            overflow: hidden;
        }

        .perfil-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(212, 163, 115, 0.03), transparent 50%);
            pointer-events: none;
        }

        .perfil-card:hover {
            transform: translateY(-8px) scale(1.01);
            border-color: rgba(212, 163, 115, 0.15);
            box-shadow: 0 16px 60px rgba(0, 0, 0, 0.3);
        }

        .perfil-card h3 {
            font-family: 'Cinzel', serif;
            font-size: 1.2rem;
            color: #d4a373;
            margin-bottom: 0.8rem;
            letter-spacing: 0.05em;
        }

        .perfil-card ul {
            list-style: none;
            padding: 0;
        }

        .perfil-card li {
            padding: 0.4rem 0;
            border-bottom: 1px solid rgba(212, 163, 115, 0.04);
            transition: all 0.3s ease;
            font-size: 0.95rem;
            color: #c8c0b8;
        }
        .perfil-card li:last-child {
            border-bottom: none;
        }
        .perfil-card li:hover {
            padding-left: 0.5rem;
            color: #e0d6c8;
        }

        .perfil-card .destaque {
            color: #d4a373;
            font-weight: 700;
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
        }

        /* ============================================================
           CAPÍTULOS — CARDS COM EFEITO DE REVELAÇÃO
        ============================================================ */
        .capitulo-card {
            background: rgba(20, 17, 14, 0.5);
            border-radius: 24px;
            border: 1px solid rgba(212, 163, 115, 0.05);
            margin-bottom: 2.5rem;
            overflow: hidden;
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            cursor: pointer;
            backdrop-filter: blur(8px);
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
        }

        .capitulo-card:hover {
            border-color: rgba(212, 163, 115, 0.15);
            transform: translateY(-6px);
            box-shadow: 0 16px 60px rgba(0, 0, 0, 0.25);
        }

        .capitulo-header {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            padding: 2rem;
            align-items: center;
        }
        @media (max-width: 700px) {
            .capitulo-header {
                grid-template-columns: 1fr;
                text-align: center;
                padding: 1.5rem;
            }
        }

        .capitulo-header img {
            width: 100%;
            height: auto;
            max-height: 200px;
            object-fit: cover;
            border-radius: 16px;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
            transition: all 0.5s ease;
        }

        .capitulo-card:hover .capitulo-header img {
            transform: scale(1.02);
            box-shadow: 0 8px 50px rgba(212, 163, 115, 0.08);
        }

        .capitulo-header h3 {
            font-family: 'Cinzel', serif;
            font-size: 1.6rem;
            color: #d4c0a0;
            margin-bottom: 0.5rem;
            transition: color 0.3s ease;
        }

        .capitulo-card:hover .capitulo-header h3 {
            color: #d4a373;
        }

        .capitulo-header blockquote {
            font-style: italic;
            color: #b8a890;
            border-left: 3px solid #d4a373;
            padding-left: 1.2rem;
            font-size: 0.95rem;
            opacity: 0.7;
        }

        .capitulo-header .abrir-indicador {
            display: inline-block;
            margin-top: 0.8rem;
            font-size: 0.7rem;
            color: #6a5f5a;
            letter-spacing: 0.15em;
            transition: all 0.3s ease;
            font-family: 'Cinzel', serif;
            text-transform: uppercase;
        }

        .capitulo-card:hover .abrir-indicador {
            color: #d4a373;
        }

        /* ============================================================
           CONTEÚDO DO CAPÍTULO
        ============================================================ */
        .capitulo-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94), padding 0.5s ease;
            padding: 0 2rem;
            background: rgba(0, 0, 0, 0.15);
            border-top: 1px solid transparent;
        }

        .capitulo-body.aberto {
            max-height: 4000px;
            padding: 2rem;
            border-top-color: rgba(212, 163, 115, 0.06);
        }

        .capitulo-body .texto {
            text-align: justify;
            margin-bottom: 1.5rem;
        }
        .capitulo-body .texto p {
            margin-bottom: 1rem;
            font-size: 1.02rem;
            color: #c8c0b8;
        }

        .capitulo-body .texto p strong {
            color: #d4a373;
            font-family: 'Cinzel', serif;
            font-weight: 700;
        }

        .capitulo-body .imagem-destaque {
            width: 100%;
            max-height: 400px;
            object-fit: cover;
            border-radius: 16px;
            margin: 1.5rem 0;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
            transition: all 0.5s ease;
        }

        .capitulo-body .imagem-destaque:hover {
            transform: scale(1.01);
            box-shadow: 0 8px 50px rgba(212, 163, 115, 0.08);
        }

        .citacao-destaque {
            font-style: italic;
            color: #b8a890;
            text-align: center;
            padding: 1.8rem 0;
            border-top: 1px solid rgba(212, 163, 115, 0.06);
            border-bottom: 1px solid rgba(212, 163, 115, 0.06);
            margin: 1.5rem 0;
            font-size: 1.1rem;
            transition: all 0.3s ease;
        }

        .citacao-destaque:hover {
            color: #d4c0a0;
            border-color: rgba(212, 163, 115, 0.15);
        }

        .citacao-destaque strong {
            color: #d4a373;
            font-style: normal;
            font-family: 'Cinzel', serif;
        }

        /* ============================================================
           BOTÕES — MINIMALISTAS
        ============================================================ */
        .btn-proximo {
            display: inline-block;
            margin-top: 1.5rem;
            padding: 0.7rem 2.5rem;
            background: transparent;
            border: 1px solid rgba(212, 163, 115, 0.15);
            border-radius: 50px;
            color: #b8a890;
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            text-decoration: none;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .btn-proximo:hover {
            background: rgba(212, 163, 115, 0.06);
            border-color: #d4a373;
            color: #f0e6d0;
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 163, 115, 0.05);
        }

        .btn-proximo.fim {
            opacity: 0.4;
            cursor: default;
        }
        .btn-proximo.fim:hover {
            background: transparent;
            border-color: rgba(212, 163, 115, 0.15);
            color: #b8a890;
            transform: none;
            box-shadow: none;
        }

        .btn-voltar {
            display: inline-block;
            margin-top: 2.5rem;
            padding: 0.8rem 2.5rem;
            background: transparent;
            border: 1px solid rgba(212, 163, 115, 0.12);
            border-radius: 50px;
            color: #d4a373;
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            text-decoration: none;
            letter-spacing: 0.05em;
        }

        .btn-voltar:hover {
            background: rgba(212, 163, 115, 0.06);
            border-color: #d4a373;
            color: #f0e6d0;
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(212, 163, 115, 0.05);
        }

        /* ============================================================
           RODAPÉ
        ============================================================ */
        .footer-simbolo {
            text-align: center;
            font-size: 1.2rem;
            letter-spacing: 0.3em;
            color: #4a3f3a;
            margin-top: 4rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(212, 163, 115, 0.04);
            opacity: 0.5;
        }

        /* ============================================================
           CONTROLE DE MÚSICA
        ============================================================ */
        .music-control {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            z-index: 10;
            background: rgba(20, 17, 14, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(180, 150, 200, 0.08);
            color: #d4c8e8;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            font-size: 1.4rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        }

        .music-control:hover {
            background: rgba(30, 25, 20, 0.9);
            border-color: #d4a373;
            transform: scale(1.08) rotate(8deg);
            box-shadow: 0 0 30px rgba(212, 163, 115, 0.05);
        }

        /* ============================================================
           ANIMAÇÕES DE ENTRADA
        ============================================================ */
        .fade-in {
            opacity: 0;
            transform: translateY(30px);
            animation: fadeUp 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;
        }
        @keyframes fadeUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .delay-1 {
            animation-delay: 0.15s;
        }
        .delay-2 {
            animation-delay: 0.4s;
        }
        .delay-3 {
            animation-delay: 0.7s;
        }
        .delay-4 {
            animation-delay: 1s;
        }

        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: #0a0806;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(212, 163, 115, 0.2);
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(212, 163, 115, 0.4);
        }
    </style>
</head>
<body>

